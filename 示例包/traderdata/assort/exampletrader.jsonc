                "parentId": "hideout",
                "slotId": "hideout",
                "upd": {
                    "BuyRestrictionMax": 100,
                    "BuyRestrictionCurrent": 0,
                    "StackObjectsCount": 999999,
                    "UnlimitedCount": true
                }
            }
        ],
        "DogTag": {},
        "Barter": {
            "示例货币": 100
        },
        "TrustLevel": 1,
        "isWeapon": false
    },
