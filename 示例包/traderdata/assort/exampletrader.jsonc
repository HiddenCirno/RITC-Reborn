[
    //报价单合并文件
    {
        //普通报价单(和锁定区分)
        "$type": "normal",
        //ID(需要和主物品的ID一致)
        "ID": "报价单范例1",
        //报价单所属的商人
        "Trader": "ExampleTrader",
        //物品内容
        "Item": [
            {
                //主物品(parentId和slotId为hideout, 一个报价单只能有一个主物品)
                //主物品的识别ID, 全局唯一不可重复
                "_id": "报价单范例1",
                //主物品的物品ID(具体的物品)
                "_tpl": "示例物品1",
                //parentId和slotId, 此处用于标识主物品和构建树结构
                "parentId": "hideout",
                "slotId": "hideout",
                //upd, 存储报价单的部分数据
                "upd": {
                    //最大购买数量
                    "BuyRestrictionMax": 1,
                    //已购买数量, 无用, 仅做保留, 填0即可
                    "BuyRestrictionCurrent": 0,
                    //商人处一次补货的物品数量
                    "StackObjectsCount": 999999,
                    //不显示具体存货数量(即显示为"大量")
                    "UnlimitedCount": true
                }
            }
        ],
        //交易部分
        //狗牌需求, 此处留空, 见下
        "DogTag": {},
        //物品需求, KvP(Key-Value-Pair结构, 物品id: 数量)
        "Barter": {
            //物品id后面跟数量
            "590a373286f774287540368b": 1,
            "5d0376a486f7747d8050965c": 1
        },
        //需要的信任度等级
        "TrustLevel": 1,
        //是否为武器, 此参数已失去作用, 仅做保留
        "isWeapon": false
    },
    {
        "$type": "normal",
        "ID": "报价单范例2",
        "Trader": "ExampleTrader",
        "Item": [
            {
                "_id": "报价单范例2",
                "_tpl": "示例物品1",
                "parentId": "hideout",
                "slotId": "hideout",
                "upd": {
                    "BuyRestrictionMax": 1,
                    "BuyRestrictionCurrent": 0,
                    "StackObjectsCount": 999999,
                    "UnlimitedCount": true
                }
            }
        ],
        //狗牌交易内容
        //狗牌交易疑似是不识别物品ID的, 只依靠阵营和等级作区分, 物品ID仅做显示用
        //这里使用默认的Bear和Usec狗牌
        "DogTag": {
            //狗牌id对应的数据
            "59f32c3b86f77472a31742f0": {
                //数量
                "count": 1,
                //等级
                "level": 20,
                //阵营
                "side": "Usec"
            },
            "59f32bb586f774757e1e8442": {
                "count": 1,
                "level": 20,
                "side": "Bear"
            }
        },
        "Barter": {},
        "TrustLevel": 1
    },
    {
        //锁定的报价单, 需要完成任务解锁
        "$type": "locked",
        "ID": "报价单范例3",
        "Trader": "ExampleTrader",
        "Item": [
            {
                "_id": "报价单范例3",
                "_tpl": "示例物品1",
                "parentId": "hideout",
                "slotId": "hideout",
                "upd": {
                    "BuyRestrictionMax": 1,
                    "BuyRestrictionCurrent": 0,
                    "StackObjectsCount": 999999,
                    "UnlimitedCount": true
                }
            }
        ],
        "DogTag": {
            "59f32bb586f774757e1e8442": {
                "count": 1,
                "level": 20,
                "side": "Any"
            }
        },
        "Barter": {},
        "TrustLevel": 1,
        "isWeapon": false,
        //是否锁定
        "Locked": true,
        //任务ID
        //报价单并不支持成就解锁
        "Quest": "示例任务1",
        //任务状态, 0开始1完成2失败
        "QuestStage": 1,
        //是否为未知奖励
        "Unknown": false
    },
    {
        "$type": "normal",
        "ID": "报价单范例4",
        "Trader": "ExampleTrader",
        "Item": [
            {
                "_id": "报价单范例4",
